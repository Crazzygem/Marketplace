# =============================================================================
# Marketplace Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your deployment.
#   cp .env.example .env
#   nano .env
# =============================================================================

# ----- Application -----
APP_NAME=Marketplace
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost

# ----- Database -----
DB_DATABASE=marketplace
DB_USERNAME=marketplace
DB_PASSWORD=secret_password
MYSQL_ROOT_PASSWORD=root_secret

# ----- Ports (host ports) -----
NGINX_PORT=80
MYSQL_PORT=3306
REDIS_PORT=6379

# ----- Docker -----
COMPOSE_PROJECT_NAME=marketplace
